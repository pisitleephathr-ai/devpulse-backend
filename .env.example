# PostgreSQL connection string.
# Local:   postgresql://USER:PASSWORD@localhost:5432/devpulse?schema=public
# Railway: copy the "DATABASE_URL" from the Postgres plugin's Variables tab
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/devpulse?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV="development"

# CORS — the frontend origin (use * for local dev)
CORS_ORIGIN="http://localhost:3000"

# LINE Official Account — push task notifications into a team LINE group.
# Leave LINE_ENABLED=false (default) to disable entirely. To enable:
#  1) Create a LINE OA + Messaging API channel; copy its channel access token
#     AND its channel secret.
#  2) In the channel's Messaging API settings, set the Webhook URL to
#     https://<your-backend-host>/api/line/webhook and turn "Use webhook" on.
#  3) Allow the bot to join group chats (LINE Official Account Manager), then
#     invite the bot to your team's LINE group. The group id is then captured
#     automatically from the first webhook event — no manual lookup needed.
# LINE_GROUP_ID is an optional manual override; leave it empty to use the
# auto-captured id stored on TeamSetting.
LINE_ENABLED="false"
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""
LINE_GROUP_ID=""
