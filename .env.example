# PostgreSQL connection string.
# Local:   postgresql://USER:PASSWORD@localhost:5432/devpulse?schema=public
# Railway: copy the "DATABASE_URL" from the Postgres plugin's Variables tab
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/devpulse?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV="development"

# CORS — the frontend origin (use * for local dev)
CORS_ORIGIN="http://localhost:3000"

# Public frontend URL — used to build "open task" links inside LINE cards.
# Set this to your deployed frontend (e.g. https://your-app.vercel.app).
# If empty, falls back to CORS_ORIGIN when that is a single URL.
APP_URL=""

# LINE Official Account — push task notifications into a team LINE group.
# Leave LINE_ENABLED=false (default) to disable entirely. To enable:
#  1) Create a LINE OA + Messaging API channel; copy its channel access token
#     AND its channel secret.
#  2) In the channel's Messaging API settings, set the Webhook URL to
#     https://<your-backend-host>/api/line/webhook and turn "Use webhook" on.
#  3) Allow the bot to join group chats (LINE Official Account Manager), then
#     invite the bot to your team's LINE group. The group id is then captured
#     automatically from the first webhook event — no manual lookup needed.
# LINE_GROUP_ID is an optional manual override; leave it empty to use the
# auto-captured id stored on TeamSetting.
LINE_ENABLED="false"
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""
LINE_GROUP_ID=""

# Shared secret for the external-cron endpoints (LINE summaries + attachment
# cleanup). When set, callers must present it as a Bearer token / x-cron-secret
# header / ?secret= query param. Leave empty to disable those endpoints.
CRON_SECRET=""

# Cloudinary — signed direct upload for task attachments.
# Create a free account at https://cloudinary.com, then copy these from the
# dashboard (Settings → API Keys). Signed uploads only — the API secret is
# SERVER-ONLY and must NEVER be exposed to the frontend, a NEXT_PUBLIC_* var, an
# API response, a log, or version control. Leave all three empty to disable
# uploads entirely (the endpoints return 503; legacy URL attachments still work).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Root folder for uploaded assets. Per-task assets live under
# ${CLOUDINARY_UPLOAD_FOLDER}/tasks/{taskId}. Defaults to "devpulse".
CLOUDINARY_UPLOAD_FOLDER="devpulse"
