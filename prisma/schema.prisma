// DevPulse database schema — PostgreSQL + Prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ----------------------------- Enums ----------------------------- */

enum Role {
  MANAGER
  ADMIN
  DEVELOPER
  QA
}

enum ReportStatus {
  SUBMITTED
  DRAFT
  LATE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum LeaveType {
  VACATION
  SICK
  PERSONAL
  PARENTAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

/* ----------------------------- Models ---------------------------- */

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(DEVELOPER)
  /// short key used by the frontend to pick avatar colors, e.g. "Maya"
  avatarKey String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports        DailyReport[]
  assignedTasks  Task[]
  leaveRequests  LeaveRequest[] @relation("LeaveRequester")
  reviewedLeaves LeaveRequest[] @relation("LeaveReviewer")
  activityLogs   ActivityLog[]

  @@index([role])
}

model Project {
  id        String   @id @default(cuid())
  name      String   @unique
  /// short code shown on task cards, e.g. "ATLAS"
  code      String   @unique
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports DailyReport[]
  tasks   Task[]
}

model DailyReport {
  id        String       @id @default(cuid())
  date      DateTime
  summary   String
  did       String
  blockers  String       @default("")
  plan      String       @default("")
  status    ReportStatus @default(SUBMITTED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  author    User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  project   Project @relation(fields: [projectId], references: [id])
  projectId String

  @@index([authorId])
  @@index([projectId])
  @@index([date])
}

model Task {
  id        String       @id @default(cuid())
  title     String
  priority  TaskPriority @default(MEDIUM)
  status    TaskStatus   @default(TODO)
  dueDate   DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project    Project @relation(fields: [projectId], references: [id])
  projectId  String
  assignee   User?   @relation(fields: [assigneeId], references: [id])
  assigneeId String?

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

model LeaveRequest {
  id        String      @id @default(cuid())
  type      LeaveType
  startDate DateTime
  endDate   DateTime
  days      Int
  reason    String
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user         User    @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  reviewedBy   User?   @relation("LeaveReviewer", fields: [reviewedById], references: [id])
  reviewedById String?

  @@index([userId])
  @@index([status])
}

model ActivityLog {
  id         String   @id @default(cuid())
  /// machine key, e.g. "report.create", "leave.approve"
  action     String
  /// human-readable Thai message shown in the activity feed
  message    String
  entityType String?
  entityId   String?
  createdAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
  @@index([createdAt])
}
