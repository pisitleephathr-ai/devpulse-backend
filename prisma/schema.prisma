// DevPulse database schema — PostgreSQL + Prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ----------------------------- Enums ----------------------------- */

/// Legacy role enum, kept only for backward compatibility on existing rows.
/// Role assignment now uses the dynamic Role table via User.roleId.
enum UserRole {
  MANAGER
  ADMIN
  DEVELOPER
  QA
}

enum ReportStatus {
  SUBMITTED
  DRAFT
  LATE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  READY_TO_TEST
  DONE
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

/// How a task attachment was provided.
/// - URL: a plain link the user pasted (legacy behavior, still supported)
/// - CLOUDINARY: a file uploaded to Cloudinary via signed direct upload
enum AttachmentSource {
  URL
  CLOUDINARY
}

/// Coarse attachment classification, used to drive preview vs. download UI.
enum AttachmentKind {
  IMAGE
  DOCUMENT
  LINK
}

/* ----------------------------- Models ---------------------------- */

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  /// legacy enum — retained for backward compatibility; roleId is the source of truth
  role      UserRole? @default(DEVELOPER)
  roleId    String?
  roleRef   Role?     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  /// short key used by the frontend to pick avatar colors, e.g. "Maya"
  avatarKey String
  active    Boolean   @default(true)
  /// whether this user is expected to submit a daily report (drives the
  /// dashboard "missing report" calculation). Some users are exempt.
  requiresDailyReport Boolean @default(true)
  /// LINE Messaging API user id for this user (the id the OA sees), set once the
  /// user links their personal LINE via a link code. Enables per-user DM push.
  /// Server-only — never returned in public user payloads.
  lineUserId String?  @unique
  /// when the personal LINE account was linked (for display + audit)
  lineLinkedAt DateTime?
  /// Per-user personal-LINE DM preferences — each user opts in/out of the
  /// personal notifications they receive (independent of the team's group prefs).
  lineNotifyTaskAssigned   Boolean @default(true)
  lineNotifyLeaveDecision  Boolean @default(true)
  lineNotifyReportReminder Boolean @default(true)
  /// (for approvers) DM when a new leave request is submitted
  lineNotifyLeaveRequest   Boolean @default(true)
  /// DM when a task you're assigned to changes status
  lineNotifyTaskStatus     Boolean @default(true)
  /// DM when you're @-mentioned in a task comment
  lineNotifyMention        Boolean @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  reports        DailyReport[]
  assignedTasks  Task[]
  leaveRequests  LeaveRequest[] @relation("LeaveRequester")
  reviewedLeaves LeaveRequest[] @relation("LeaveReviewer")
  activityLogs   ActivityLog[]
  notifications  Notification[]
  taskComments   TaskComment[]
  taskAssignments TaskAssignee[] @relation("TaskAssigneeUser")
  taskAssignedBy  TaskAssignee[] @relation("TaskAssignedBy")
  uploadedAttachments TaskAttachment[] @relation("AttachmentUploader")
  uploadIntents  UploadIntent[]
  lineLinkCode   LineLinkCode?

  @@index([role])
  @@index([roleId])
}

/// Short-lived code a user generates in their profile to link their personal
/// LINE account. They send it to the OA in a 1:1 chat; the webhook matches an
/// unexpired code to bind that LINE user id to this user. Single active code per
/// user (regenerating replaces it); consumed (deleted) on a successful match.
model LineLinkCode {
  /// the code the user types into the LINE chat (uppercase, unambiguous chars)
  code      String   @id
  userId    String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

/// Dynamic, admin-managed roles. Replaces the hardcoded UserRole enum.
model Role {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String   @default("")
  /// system roles cannot be deleted
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  /// capability grants, e.g. ["TEAM_MANAGE","ADMIN_FULL"]. Additive: the legacy
  /// ADMIN/MANAGER codes still grant access on their own; permissions let
  /// custom roles gain the same capabilities.
  permissions String[] @default([])
  /// whether users with this role appear on the task board — i.e. can be
  /// assigned tasks and show in the dashboard team-workload list. Purely a
  /// team-membership flag (editable for system roles too, unlike permissions);
  /// system-admin roles default to false so admins aren't listed as workers.
  assignable  Boolean  @default(true)
  /// sidebar menu keys this role may see, e.g. ["dashboard","reports"]. Empty
  /// means "inherit the built-in defaults for this role code". A navigation
  /// visibility layer only — API routes stay guarded by permissions.
  menuAccess  String[] @default([])
  /// personal-LINE notification types members of this role are ALLOWED to
  /// receive, e.g. ["taskAssigned","leaveDecision"]. Empty = all types allowed
  /// (default). Users then opt in/out within this set.
  lineNotifications String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model Project {
  id          String    @id @default(cuid())
  name        String    @unique
  /// short code shown on task cards, e.g. "ATLAS"
  code        String    @unique
  color       String
  description String    @default("")
  /// free-form lifecycle status, e.g. "ACTIVE" | "ON_HOLD" | "COMPLETED"
  status      String    @default("ACTIVE")
  isArchived  Boolean   @default(false)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  reports DailyReport[]
  tasks   Task[]

  @@index([isArchived])
}

model DailyReport {
  id        String       @id @default(cuid())
  date      DateTime
  summary   String
  did       String
  blockers  String       @default("")
  plan      String       @default("")
  status    ReportStatus @default(SUBMITTED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  author    User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId  String
  project   Project @relation(fields: [projectId], references: [id])
  projectId String
  /// optional board tasks this report references (additive, never required)
  relatedTasks DailyReportRelatedTask[]

  @@index([authorId])
  @@index([projectId])
  @@index([date])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  /// optional details; importer stores "Progress: NN%" + "Note: ..." here
  description String       @default("")
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  dueDate     DateTime?
  /// when the task first entered DONE (set on that transition, cleared if it
  /// leaves DONE). Drives on-time-vs-late completion metrics against dueDate.
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project     Project          @relation(fields: [projectId], references: [id])
  projectId   String
  /// legacy single assignee — kept as the "primary" for backward compatibility;
  /// full set lives in the `assignees` join table
  assignee    User?            @relation(fields: [assigneeId], references: [id])
  assigneeId  String?
  assignees   TaskAssignee[]
  links       TaskLink[]
  attachments TaskAttachment[]
  uploadIntents UploadIntent[]
  comments    TaskComment[]
  checklist   TaskChecklistItem[]
  /// daily reports that optionally reference this task (additive)
  reportRelations DailyReportRelatedTask[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
}

/// A subtask / checklist item under a task. Cascade-deleted with the task.
model TaskChecklistItem {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  text      String
  done      Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

/// Optional link between a daily report and a board task it references.
/// Reports stay free-form — this relation is additive and never required.
/// A report can reference many tasks; a task can appear in many reports.
model DailyReportRelatedTask {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  /// user who added the link (optional, informational only)
  createdById String?

  report   DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reportId String
  task     Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId   String

  @@unique([reportId, taskId])
  @@index([reportId])
  @@index([taskId])
}

/// Many-to-many task ⇄ user assignment. A task can have multiple assignees.
model TaskAssignee {
  id           String   @id @default(cuid())
  assignedAt   DateTime @default(now())
  assignedById String?

  task       Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId     String
  user       User  @relation("TaskAssigneeUser", fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  assignedBy User? @relation("TaskAssignedBy", fields: [assignedById], references: [id])

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

/// Discussion thread on a task. Soft-deleted (isDeleted) so history is kept.
model TaskComment {
  id        String    @id @default(cuid())
  message   String
  isEdited  Boolean   @default(false)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId   String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId String

  @@index([taskId])
  @@index([authorId])
}

model TaskLink {
  id        String   @id @default(cuid())
  title     String
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String

  @@index([taskId])
}

model TaskAttachment {
  id        String   @id @default(cuid())

  /// Legacy fields — retained so existing URL attachments keep working and so
  /// every attachment (URL or Cloudinary) has a stable display name + href.
  /// For CLOUDINARY rows these mirror originalName / secureUrl.
  fileName  String
  fileUrl   String
  fileType  String?
  fileSize  Int?

  /// How the attachment was provided. Defaults to URL so existing rows and the
  /// legacy "paste a link" endpoint are classified correctly; Cloudinary
  /// uploads set this explicitly.
  source    AttachmentSource @default(URL)
  /// Preview/download hint. Legacy rows default to LINK (the client still infers
  /// image-vs-file from the URL); uploads set IMAGE or DOCUMENT explicitly.
  kind      AttachmentKind   @default(LINK)

  /// Original client-provided filename (sanitized) + optional display override.
  originalName String?
  displayName  String?
  mimeType     String?
  extension    String?

  /// Cloudinary asset identity (null for URL attachments).
  cloudinaryPublicId     String?
  cloudinaryVersion      Int?
  cloudinaryAssetId      String?
  cloudinaryResourceType String?
  cloudinaryFormat       String?

  /// Canonical secure URL + a derived thumbnail (images only).
  secureUrl    String?
  thumbnailUrl String?

  width  Int?
  height Int?

  /// Who uploaded it (null for legacy rows / seed data).
  uploadedById String?
  uploadedBy   User?   @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  /// Cloudinary deletion bookkeeping so a failed remote delete can be retried by
  /// the cleanup job instead of silently leaking the asset.
  deleteStatus String?
  deletedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String

  @@unique([cloudinaryAssetId])
  @@index([taskId])
  @@index([uploadedById])
}

/// Short-lived record of a signed-upload grant. Created when a signature is
/// issued and consumed once when the client confirms the upload, which both
/// binds the eventual asset to a specific task+user and prevents replay /
/// duplicate attachments. Expired PENDING intents are swept by the cleanup job,
/// which deletes any orphaned Cloudinary asset that never got confirmed.
model UploadIntent {
  id           String    @id @default(cuid())
  taskId       String
  userId       String
  /// The Cloudinary public id the signature was scoped to (unique → single use).
  publicId     String    @unique
  fileName     String
  mimeType     String
  expectedSize Int
  resourceType String
  /// PENDING | COMPLETED | EXPIRED
  status       String    @default("PENDING")
  expiresAt    DateTime
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([expiresAt])
}

model LeaveRequest {
  id        String      @id @default(cuid())
  /// leave-type name — matches a LeaveTypePolicy.name (freeform, admin-configured).
  /// Legacy rows may hold the old enum codes (VACATION/SICK/PERSONAL/PARENTAL).
  type      String
  startDate DateTime
  endDate   DateTime
  /// number of leave days; supports halves (0.5) for half-day leave
  days      Float
  /// null = full day; "MORNING" | "AFTERNOON" for a same-day half-day leave
  halfDayPeriod String?
  reason    String
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user         User    @relation("LeaveRequester", fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  reviewedBy   User?   @relation("LeaveReviewer", fields: [reviewedById], references: [id])
  reviewedById String?

  @@index([userId])
  @@index([status])
}

model ActivityLog {
  id         String   @id @default(cuid())
  /// machine key, e.g. "report.create", "leave.approve"
  action     String
  /// human-readable Thai message shown in the activity feed
  message    String
  entityType String?
  entityId   String?
  createdAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
  @@index([createdAt])
}

/// In-app notifications shown in the header bell. Created on important events
/// (task assigned, task status changed, leave submitted/approved/rejected).
model Notification {
  id         String   @id @default(cuid())
  /// machine key, e.g. "task.assigned", "leave.approved"
  type       String
  title      String
  message    String
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

/* ------------------------- Calendar & Settings ------------------------- */

enum CalendarEventType {
  LEAVE
  DEADLINE
}

model CalendarEvent {
  id        String            @id @default(cuid())
  title     String
  startDate DateTime
  endDate   DateTime
  type      CalendarEventType
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([startDate])
}

model LeaveTypePolicy {
  id          String   @id @default(cuid())
  name        String   @unique
  /// freeform allowance label, e.g. "20 วัน / ปี"
  daysLabel   String
  color       String
  autoApprove Boolean  @default(false)
  /// archived types are hidden from pickers but kept for historical reference
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Company / public / special non-working days shown on the calendar.
model CompanyHoliday {
  id          String   @id @default(cuid())
  name        String
  /// stored at UTC midnight of the Bangkok calendar day
  date        DateTime
  description String   @default("")
  /// "COMPANY" | "PUBLIC" | "SPECIAL"
  type        String   @default("COMPANY")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model TeamSetting {
  id                 String   @id @default(cuid())
  teamName           String
  reportReminderTime String
  /// organization defaults / policy — all additive with safe defaults
  timezone                  String  @default("Asia/Bangkok")
  /// comma-separated weekday numbers that are working days (0=Sun … 6=Sat)
  workingDays               String  @default("1,2,3,4,5")
  reportDueTime             String  @default("08:30")
  requireDailyReportDefault Boolean @default(true)
  allowHalfDayLeave         Boolean @default(true)
  notifyReportReminder      Boolean @default(true)
  notifyLeaveApproval       Boolean @default(true)
  notifyTaskDue             Boolean @default(true)
  /// comma-separated menu ids defining sidebar order (empty = default order)
  menuOrder                 String  @default("")
  /// JSON array of sidebar menu customization: [{key, customLabel, order, isVisible}].
  /// Empty = code defaults. Controls display only — never grants page access.
  menuConfig                String  @default("")
  /// LINE group id the OA bot is in, auto-captured from webhook events. Task
  /// notifications are pushed here when LINE is enabled. Null = not linked yet.
  lineGroupId               String?
  /// master switch for PERSONAL LINE DMs (per-user notifications). When false,
  /// no personal DM is sent regardless of each user's own prefs. Group summaries
  /// / cards are unaffected. Default on.
  linePersonalEnabled       Boolean  @default(true)
  /// LINE OA notification prefs — which task events fan out to the group.
  lineNotifyNewTask         Boolean  @default(true)
  /// task statuses that trigger a LINE card when moved to them
  lineNotifyStatuses        String[] @default(["TODO", "DONE"])
  /// push a LINE card when a leave request is submitted / approved / rejected
  lineNotifyLeave           Boolean  @default(true)
  /// daily "who's on leave today" summary → LINE group at lineDailyLeaveSummaryTime
  lineDailyLeaveSummary     Boolean  @default(false)
  /// HH:mm (Bangkok) the leave summary is sent, on working days only
  lineDailyLeaveSummaryTime String   @default("09:00")
  /// daily report summary (submitted / missing) → LINE group at lineDailyReportSummaryTime
  lineDailyReportSummary    Boolean  @default(false)
  /// HH:mm (Bangkok) the report summary is sent, on working days only
  lineDailyReportSummaryTime String  @default("18:00")
  /// weekly team-performance summary (on-time ranking) → LINE group, sent on
  /// Mondays at lineWeeklyPerformanceTime.
  lineWeeklyPerformance     Boolean  @default(false)
  lineWeeklyPerformanceTime String   @default("09:00")
  /// dedup guards — YYYY-MM-DD (Bangkok) each daily summary last fired. Internal.
  lineLeaveSummaryLastRun   String?
  lineReportSummaryLastRun  String?
  lineWeeklyPerformanceLastRun String?
  updatedAt          DateTime @updatedAt
}
